/*
 * linker.ld – описывает расположение секций ядра в памяти
 * Точка входа – метка _start, ядро загружается по адресу 0x1000
 */
ENTRY(_start)

SECTIONS
{
    . = 0x1000;         /* Базовый адрес ядра */

    .text : {
        *(.text*)       /* весь код */
    }
    .rodata : {
        *(.rodata*)     /* read-only данные (строки) */
    }
    .data : {
        *(.data)        /* глобальные переменные */
    }
    .bss : {
        *(.bss)         /* неинициализированные данные */
    }
}